# ============================================
# Pantry-Pal API - Production Environment Variables
# ============================================
# IMPORTANT: These values should be configured in Railway Dashboard
# NEVER commit this file with real values

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Origins (comma-separated) - UPDATE WITH YOUR DOMAIN
CORS_ORIGINS=https://pantry-pal.app,https://www.pantry-pal.app

# Database Type
DB_TYPE=postgres

# PostgreSQL Configuration - Railway provides DATABASE_URL automatically
# DATABASE_URL=postgresql://...
# DB_HOST=
# DB_PORT=5432
# DB_NAME=pantry_pal
# DB_USER=
# DB_PASSWORD=
# DB_SSL=true

# Authentication (Clerk) - USE PRODUCTION KEYS
CLERK_SECRET_KEY=sk_live_your_production_key_here

# Stripe Configuration - USE PRODUCTION KEYS
STRIPE_SECRET_KEY=sk_live_your_production_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Pricing (Stripe Price IDs) - USE PRODUCTION PRICES
STRIPE_PRICE_PRO_MONTHLY=price_live_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_live_pro_yearly

# Feature Flags / Usage Limits
FREE_TIER_RECEIPT_SCANS=10
FREE_TIER_AI_CALLS=50
FREE_TIER_VOICE_SESSIONS=5
PRO_TIER_RECEIPT_SCANS=100
PRO_TIER_AI_CALLS=500
PRO_TIER_VOICE_SESSIONS=50

# Error Monitoring (Sentry) - ADD YOUR DSN
SENTRY_DSN=https://xxxxxx@xxxx.ingest.sentry.io/xxxxx

# Railway Specific
# RAILWAY_GIT_COMMIT_SHA=auto_set_by_railway
